<Window x:Class="MMCSSTweaker.Controls.DarkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding TitleText}"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        KeyDown="Window_OnKeyDown">
    <Border
        BorderBrush="{StaticResource BorderBrushDark}"
        BorderThickness="1"
        Background="{StaticResource WindowBackground}"
        SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{StaticResource ControlBackground}"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <TextBlock
                    Text="{Binding TitleText}"
                    FontWeight="Bold"
                    FontSize="13"
                    Margin="12,0,44,0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource LabelForeground}"/>
                <Button
                    Content="X"
                    Style="{StaticResource DialogCloseButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Click="CloseButton_OnClick"/>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource BorderBrushDark}"/>

            <Grid Grid.Row="2"
                  Margin="22"
                  MinWidth="420"
                  MaxWidth="640">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="{Binding MessageText}"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource LabelForeground}"
                    FontSize="14"
                    MaxWidth="600"/>

                <Button
                    Grid.Row="1"
                    Content="OK"
                    Style="{StaticResource DialogButtonStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0"
                    IsDefault="True"
                    Click="OkButton_OnClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
